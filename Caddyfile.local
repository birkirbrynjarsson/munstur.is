	rewrite /baekur/utskurdarmynstur.php /baekur/utskurdarmynstur.html
	rewrite /baekur/utsogunarmynstur.php /baekur/utsogunarmynstur.html
	rewrite /baekur/tuskudyr.php /baekur/tuskudyr.html
