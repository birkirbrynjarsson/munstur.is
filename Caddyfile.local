	rewrite /munstur.php /munstur.html
	rewrite /altarisdukar.php /altarisdukar.html
	rewrite /altarisdukamunstur.php /altarisdukamunstur.html
	rewrite /frettabladid-2016.php /frettabladid-2016.html
	rewrite /huguroghond.php /huguroghond.html
	rewrite /huguroghond-2018.php /huguroghond-2018.html
	rewrite /baekur/hannyrdir.php /baekur/hannyrdir.html
	rewrite /baekur/vefnadur.php /baekur/vefnadur.html
	rewrite /baekur/utsaumur.php /baekur/utsaumur.html
